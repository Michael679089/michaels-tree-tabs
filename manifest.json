{
  "manifest_version": 2,
  "name": "Vertical Tree Tabs (Michael's Fork)",
  "version": "1.5.4",
  "description": "Display your tabs as a tree in a sidebar. This is a fork from this project: https://addons.mozilla.org/en-US/firefox/addon/vertical-tree-tabs/",
  "browser_specific_settings": {
    "gecko": {
      "id": "vertical_tree_tabs@github.com-michael679089",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "permissions": [
    "tabs",
    "sessions",
    "menus",
    "menus.overrideContext"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_icon": "icon.svg"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "F1"
      }
    }
  }
}